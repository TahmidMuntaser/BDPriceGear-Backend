# Ensure shell scripts always use LF (Unix) line endings, even on Windows
*.sh text eol=lf

# Python files
*.py text eol=lf

# Config files
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf

# Documentation
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite3 binary

# Local Development Settings (EXAMPLE - DO NOT USE IN PRODUCTION)
# Copy this file to .env and fill in your actual values

# Django Secret Key - Generate a new one for production
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY='your-secret-key-here'

# Debug mode - NEVER set to True in production
DEBUG=True

# Database - PostgreSQL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Production Settings (for Render/Railway)
# Set these in your hosting platform's environment variables, NOT here:
#
# DATABASE_URL=postgresql://postgres.xxx:YOUR_PASSWORD@aws-0-xxx.pooler.supabase.com:6543/postgres
# REDIS_URL=rediss://default:YOUR_PASSWORD@your-redis.upstash.io:6379
# SECRET_KEY=YOUR_PRODUCTION_SECRET_KEY
# DEBUG=False
